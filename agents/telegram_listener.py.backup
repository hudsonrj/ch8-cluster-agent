# ADICIONAR no topo do arquivo (após os imports existentes):
import requests
import tempfile
import os
from pathlib import Path

# LOCALIZAR a função que processa mensagens (geralmente handle_message ou similar)
# ADICIONAR esta nova função ANTES dela:

async def transcribe_voice_message(bot, file_id: str) -> str:
    """
    Baixa arquivo de áudio do Telegram e transcreve via STT agent
    
    Args:
        bot: Instância do bot do Telegram
        file_id: ID do arquivo de voz/áudio no Telegram
    
    Returns:
        Texto transcrito ou mensagem de erro
    """
    try:
        # 1. Obter informações do arquivo
        file = await bot.get_file(file_id)
        file_path = file.file_path
        
        # 2. Baixar arquivo
        file_url = f"https://api.telegram.org/file/bot{bot.token}/{file_path}"
        audio_response = requests.get(file_url, timeout=30)
        audio_response.raise_for_status()
        
        # 3. Salvar temporariamente
        with tempfile.NamedTemporaryFile(delete=False, suffix='.ogg') as temp_file:
            temp_file.write(audio_response.content)
            temp_path = temp_file.name
        
        try:
            # 4. Enviar para STT agent
            with open(temp_path, 'rb') as audio_file:
                files = {'file': ('voice.ogg', audio_file, 'audio/ogg')}
                stt_response = requests.post(
                    'http://127.0.0.1:7882/transcribe',
                    files=files,
                    timeout=60
                )
                stt_response.raise_for_status()
            
            # 5. Extrair transcrição
            result = stt_response.json()
            transcription = result.get('text', result.get('transcription', ''))
            
            if not transcription:
                return "[ERRO] STT agent retornou resposta vazia"
            
            print(f"[VOZ TRANSCRITA] {transcription}")
            return transcription
            
        finally:
            # 6. Limpar arquivo temporário
            if os.path.exists(temp_path):
                os.unlink(temp_path)
                
    except requests.Timeout:
        return "[ERRO] Timeout ao processar áudio - arquivo muito grande ou STT agent não respondeu"
    except requests.RequestException as e:
        return f"[ERRO] Falha na comunicação com STT agent: {str(e)}"
    except Exception as e:
        return f"[ERRO] Falha ao transcrever áudio: {str(e)}"


# LOCALIZAR a função que processa mensagens recebidas
# Exemplo: async def handle_message(update, context):
# MODIFICAR para incluir detecção de voz:

async def handle_message(update, context):
    """Processa mensagens recebidas (texto, voz, áudio)"""
    message = update.message
    
    # Código existente para obter chat_id, user_id, etc...
    chat_id = message.chat_id
    user_id = message.from_user.id
    username = message.from_user.username or message.from_user.first_name
    
    # ADICIONAR ESTA SEÇÃO (antes do processamento de texto):
    
    # Detectar e processar mensagens de voz
    if message.voice:
        print(f"[TELEGRAM] Mensagem de voz recebida de {username} (chat: {chat_id})")
        await context.bot.send_chat_action(chat_id=chat_id, action='typing')
        
        transcription = await transcribe_voice_message(context.bot, message.voice.file_id)
        
        if transcription.startswith('[ERRO]'):
            await message.reply_text(f"❌ {transcription}")
            return
        
        # Processar transcrição como texto normal
        message_text = transcription
        print(f"[VOZ→TEXTO] {username}: {message_text}")
    
    # Detectar e processar arquivos de áudio
    elif message.audio:
        print(f"[TELEGRAM] Arquivo de áudio recebido de {username} (chat: {chat_id})")
        await context.bot.send_chat_action(chat_id=chat_id, action='typing')
        
        transcription = await transcribe_voice_message(context.bot, message.audio.file_id)
        
        if transcription.startswith('[ERRO]'):
            await message.reply_text(f"❌ {transcription}")
            return
        
        message_text = transcription
        print(f"[ÁUDIO→TEXTO] {username}: {message_text}")
    
    # Mensagens de texto normais
    elif message.text:
        message_text = message.text
        print(f"[TELEGRAM] Mensagem de texto de {username}: {message_text}")
    
    else:
        # Tipo de mensagem não suportado
        await message.reply_text("❌ Tipo de mensagem não suportado. Envie texto, voz ou áudio.")
        return
    
    # CONTINUA com o código existente que processa message_text...
    # (envio para agent, salvamento no DB, etc)