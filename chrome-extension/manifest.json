{
  "manifest_version": 3,
  "name": "CH8 Cluster",
  "version": "1.0.0",
  "description": "Monitor and command your CH8 AI cluster",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://control.ch8ai.com.br/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
