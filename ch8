def _start_agent(name, script_name, port_check=None):
    """Start an agent in the background. Returns True if started."""
    import time
    pid_file = Path.home() / ".config" / "ch8" / f"{name}.pid"

    # Check if already running
    if pid_file.exists():
        try:
            pid = int(pid_file.read_text().strip())
            os.kill(pid, 0)
            return False  # already running
        except (OSError, ValueError):
            pid_file.unlink(missing_ok=True)

    script = Path(__file__).parent / "agents" / script_name
    if not script.exists():
        return False

    proc = subprocess.Popen(
        [sys.executable, str(script)],
        cwd=str(Path(__file__).parent),
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    time.sleep(0.5)
    if proc.poll() is None:
        pid_file.parent.mkdir(parents=True, exist_ok=True)
        pid_file.write_text(str(proc.pid))
        print(f"{Colors.GREEN}✓ Agent '{name}' started (PID {proc.pid}){Colors.NC}")
        return True
    return False


def _stop_agent(name):
    """Stop an agent by name."""
    import signal as _signal
    pid_file = Path.home() / ".config" / "ch8" / f"{name}.pid"
    if not pid_file.exists():
        return
    try:
        pid = int(pid_file.read_text().strip())
        os.kill(pid, _signal.SIGTERM)
    except (OSError, ValueError):
        pass
    pid_file.unlink(missing_ok=True)



def cmd_up(token=None):
    """Start the connect daemon — auto-joins the network."""
    sys.path.insert(0, str(Path(__file__).parent))
    from connect.auth import is_authenticated, login_with_token
    from connect.daemon import is_daemon_running

    # Authenticate via token if provided and not yet authenticated
    if token and not is_authenticated():
        print(f"{Colors.BLUE}Authenticating with pre-auth token...{Colors.NC}")
        try:
            auth = login_with_token(token)
            print(f"{Colors.GREEN}✓ Authenticated  network={auth['network_id']}{Colors.NC}")
        except Exception as e:
            print(f"{Colors.RED}Token auth failed: {e}{Colors.NC}")
            sys.exit(1)

    if not is_authenticated():
        print(f"{Colors.RED}Not authenticated. Run `ch8 login` or `ch8 up --token TOKEN`{Colors.NC}")
        sys.exit(1)

    if is_daemon_running():
        print(f"{Colors.YELLOW}CH8 Connect is already running.{Colors.NC} Run `ch8 nodes` to see peers.")
        return

    # First-time setup: AI provider, channels, tools
    from connect.ai_config import is_ai_configured, load_ai_config
    from connect.ai_config import interactive_setup as ai_setup
    from connect.channels import load_channels
    from connect.channels import interactive_setup as channel_setup
    from connect.tools_config import get_all_tools
    from connect.tools_config import interactive_setup as tools_setup

    first_time = not is_ai_configured()

    if first_time:
        print(f"\n{Colors.BLUE}{'='*56}{Colors.NC}")
        print(f"{Colors.BLUE}  CH8 First-Time Node Setup{Colors.NC}")
        print(f"{Colors.BLUE}{'='*56}{Colors.NC}")

        # 1. AI Provider
        print(f"\n{Colors.YELLOW}Step 1/3:{Colors.NC} AI Provider")
        ai_setup()

        # 2. Notification channels
        print(f"\n{Colors.YELLOW}Step 2/3:{Colors.NC} Notification Channels")
        channel_setup()

        # 3. Agent tools
        print(f"\n{Colors.YELLOW}Step 3/3:{Colors.NC} Agent Tools")
        tools_setup()

        print(f"\n{Colors.GREEN}{'='*56}{Colors.NC}")
        print(f"{Colors.GREEN}  Setup complete! Starting CH8...{Colors.NC}")
        print(f"{Colors.GREEN}{'='*56}{Colors.NC}\n")
    else:
        ai = load_ai_config()
        provider = ai.get("provider", "ollama")
        model = ai.get("model", "auto")
        channels = load_channels()
        tools = get_all_tools()
        ch_name = channels[0].get("type", "none") if channels else "none"
        print(f"{Colors.GREEN}✓ AI provider  {provider} / {model}{Colors.NC}")
        print(f"{Colors.GREEN}✓ Channels     {ch_name}{Colors.NC}")
        print(f"{Colors.GREEN}✓ Tools        {len(tools)} enabled{Colors.NC}")

    # Check networking
    from connect.daemon import check_tailscale
    ts = check_tailscale()
    if not ts["installed"]:
        print(f"{Colors.YELLOW}⚠ Tailscale not found.{Colors.NC}")
        print(f"  Cross-network communication requires one of:")
        print(f"    1. Tailscale (recommended): https://tailscale.com/download")
        print(f"    2. WireGuard / VPN tunnel")
        print(f"    3. Public IP + firewall rules")
        print(f"    4. Same LAN (no setup needed)")
        print()
        print(f"  Continuing with LAN IP. Set {Colors.YELLOW}CH8_ADVERTISE_ADDR{Colors.NC} for manual override.")
        print()
    elif not ts["running"]:
        print(f"{Colors.YELLOW}⚠ Tailscale installed but not connected.{Colors.NC}")
        print(f"  Run {Colors.YELLOW}tailscale up{Colors.NC} to enable mesh networking.")
        print()
    else:
        print(f"{Colors.GREEN}✓ Tailscale  {ts['ip']}{Colors.NC}")

    print(f"{Colors.GREEN}Starting CH8 Connect...{Colors.NC}")

    # Launch daemon as background subprocess — log to file for debugging
    log_dir = Path.home() / ".config" / "ch8"
    log_dir.mkdir(parents=True, exist_ok=True)
    daemon_log = log_dir / "daemon.log"
    daemon_fh = open(daemon_log, "w")

    subprocess.Popen(
        [sys.executable, "-m", "connect.daemon"],
        cwd=str(Path(__file__).parent),
        stdout=daemon_fh,
        stderr=daemon_fh,
        start_new_session=True,
    )

    # Launch default agents
    _start_agent("orchestrator", "orchestrator.py")
    _start_agent("server-monitor", "server_monitor.py")

    # Wait for daemon to write its PID (up to 8s)
    import time
    from connect.daemon import is_daemon_running, read_state
    started = False
    for _ in range(16):
        time.sleep(0.5)
        if is_daemon_running():
            started = True
            break

    if started:
        state = read_state()
        print(f"{Colors.GREEN}✓ CH8 Connect is up!{Colors.NC}")
        print(f"  Peers online: {len(state.get('peers', []))}")
        print(f"\nRun {Colors.YELLOW}ch8 nodes{Colors.NC} to see your cluster.")
    else:
        print(f"{Colors.RED}Daemon failed to start.{Colors.NC}")
        # Show last lines of daemon log
        try:
            lines = daemon_log.read_text().strip().splitlines()
            if lines:
                print(f"  {Colors.DIM if hasattr(Colors,'DIM') else ''}Log ({daemon_log}):{Colors.NC}")
                for line in lines[-10:]:
                    print(f"    {line}")
            else:
                print(f"  No output. Check: {daemon_log}")
        except Exception:
            print(f"  Check log: {daemon_log}")


def cmd_down():
    """Stop the connect daemon and all agents."""
    sys.path.insert(0, str(Path(__file__).parent))
    from connect.daemon import get_daemon_pid, is_daemon_running, PID_FILE
    import signal as _signal

    # Stop agents first
    _stop_agent("orchestrator")
    _stop_agent("server-monitor")

    pid = get_daemon_pid()
    if not pid or not is_daemon_running():
        # Clean up stale PID file
        if PID_FILE.exists():
            PID_FILE.unlink(missing_ok=True)
        print(f"{Colors.YELLOW}CH8 Connect is not running.{Colors.NC}")
        return

    try:
        os.kill(pid, _signal.SIGTERM)
        # Wait for process to exit
        import time
        for _ in range(10):
            time.sleep(0.3)
            try:
                os.kill(pid, 0)
            except OSError:
                break
        # Clean PID file
        PID_FILE.unlink(missing_ok=True)
        print(f"{Colors.GREEN}✓ CH8 Connect stopped.{Colors.NC}")
    except OSError as e:
        PID_FILE.unlink(missing_ok=True)
        print(f"{Colors.RED}Could not stop daemon: {e}{Colors.NC}")


def cmd_nodes():
    """List all nodes in the network (including this one)."""
    sys.path.insert(0, str(Path(__file__).parent))
    from connect.auth import is_authenticated, get_node_id, get_access_token, get_network_id, CONTROL_URL
    from connect.daemon import is_daemon_running, read_state

    if not is_authenticated():
        print(f"{Colors.RED}Not authenticated. Run `ch8 login` first.{Colors.NC}")
        sys.exit(1)

    running = is_daemon_running()
    my_id   = get_node_id()

    status_color = Colors.GREEN if running else Colors.RED
    status_text  = "online" if running else "offline"
    print(f"\n{Colors.BLUE}CH8 Connect{Colors.NC}  status: {status_color}{status_text}{Colors.NC}\n")
    print(f"  This node:  {my_id}")

    # Fetch all nodes from control server (includes self)
    all_nodes = []
    try:
        import httpx
        resp = httpx.get(
            f"{CONTROL_URL}/nodes",
            params={"network_id": get_network_id()},
            headers={"Authorization": f"Bearer {get_access_token()}"},
            timeout=10,
        )
        if resp.status_code == 200:
            all_nodes = resp.json().get("nodes", [])
    except Exception:
        pass

    # Fallback to local state peers if API fails
    if not all_nodes:
        all_nodes = read_state().get("peers", [])

    if not all_nodes:
        print(f"\n  {Colors.YELLOW}No nodes online yet.{Colors.NC}")
        if not running:
            print(f"  Run {Colors.YELLOW}ch8 up{Colors.NC} to connect.")
    else:
        print(f"\n  {'NODE ID':<20} {'HOST':<20} {'ADDRESS':<18} {'STATUS':<8} {'CAPS'}")
        print(f"  {'-'*80}")
        for p in sorted(all_nodes, key=lambda n: n.get("node_id", "")):
            caps   = ",".join(p.get("capabilities", []))
            addr   = f"{p.get('address','?')}:{p.get('port',7878)}"
            host   = p.get("hostname", "?")[:18]
            nid    = p.get("node_id", "?")[:18]
            status = p.get("status", "?")
            is_me  = " (you)" if p.get("node_id") == my_id else ""
            sc     = Colors.GREEN if status == "online" else Colors.RED
            print(f"  {nid:<20} {host:<20} {addr:<18} {sc}{status:<8}{Colors.NC} {caps}{is_me}")
    print()


