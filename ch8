#!/usr/bin/env python3
"""
CH8 Agent - Interactive CLI
Distributed Multi-Node Agent System
"""

import sys
import os
import subprocess
import argparse
from pathlib import Path

# Colors
class Colors:
    BLUE = '\033[0;34m'
    GREEN = '\033[0;32m'
    YELLOW = '\033[1;33m'
    RED = '\033[0;31m'
    NC = '\033[0m'

def print_logo():
    print(f"{Colors.BLUE}")
    print("""
   _____ _   _ ___    _                    _
  / ____| | | / _ \  / \   __ _  ___ _ __ | |_
 | |    | |_| | | | / _ \ / _` |/ _ \ '_ \| __|
 | |___ |  _  | |_|/ ___ \ (_| |  __/ | | | |_
  \____|_| |_|\___/_/   \_\__, |\___|_| |_|\__|
                           |___/
    Distributed Multi-Node Agent System
    """)
    print(f"{Colors.NC}")

def cmd_help():
    """Show help message"""
    print_logo()
    print(f"{Colors.GREEN}CH8 Agent Commands:{Colors.NC}\n")
    print(f"  {Colors.YELLOW}ch8{Colors.NC}                - Interactive mode (start cluster)")
    print(f"  {Colors.YELLOW}ch8 start{Colors.NC}          - Start the cluster (master + workers)")
    print(f"  {Colors.YELLOW}ch8 stop{Colors.NC}           - Stop all cluster components")
    print(f"  {Colors.YELLOW}ch8 status{Colors.NC}         - Check cluster status")
    print(f"  {Colors.YELLOW}ch8 test{Colors.NC}           - Run end-to-end tests")
    print(f"  {Colors.YELLOW}ch8 logs{Colors.NC}           - View cluster logs")
    print(f"  {Colors.YELLOW}ch8 config{Colors.NC}         - Configure cluster settings")
    print(f"  {Colors.YELLOW}ch8 worker add{Colors.NC}     - Add a new worker node")
    print(f"  {Colors.YELLOW}ch8 worker list{Colors.NC}    - List all workers")
    print(f"  {Colors.YELLOW}ch8 master{Colors.NC}         - Start master node only")
    print(f"  {Colors.YELLOW}ch8 setup{Colors.NC}          - Run full setup wizard")
    print(f"  {Colors.YELLOW}ch8 update{Colors.NC}         - Update to latest version")
    print(f"  {Colors.YELLOW}ch8 doctor{Colors.NC}         - Diagnose system issues")
    print(f"  {Colors.YELLOW}ch8 help{Colors.NC}           - Show this help message")
    print()

def cmd_start():
    """Start the cluster"""
    print(f"{Colors.GREEN}Starting CH8 Agent Cluster...{Colors.NC}")
    subprocess.run(["bash", "test-cluster.sh"])

def cmd_stop():
    """Stop the cluster"""
    print(f"{Colors.YELLOW}Stopping CH8 Agent Cluster...{Colors.NC}")
    subprocess.run(["bash", "stop-cluster.sh"])

def cmd_status():
    """Check cluster status"""
    print(f"{Colors.BLUE}Checking cluster status...{Colors.NC}\n")
    subprocess.run(["python", "test-e2e.py"])

def cmd_test():
    """Run tests"""
    print(f"{Colors.BLUE}Running tests...{Colors.NC}\n")
    subprocess.run(["python", "test-e2e.py"])
    print()
    subprocess.run(["python", "test-submit.py"])

def cmd_logs(component=None):
    """View logs"""
    if component == "master":
        subprocess.run(["tail", "-f", "/tmp/ch8-master.log"])
    elif component == "worker1":
        subprocess.run(["tail", "-f", "/tmp/ch8-worker1.log"])
    elif component == "worker2":
        subprocess.run(["tail", "-f", "/tmp/ch8-worker2.log"])
    else:
        print(f"{Colors.YELLOW}Available logs:{Colors.NC}")
        print(f"  ch8 logs master   - Master node logs")
        print(f"  ch8 logs worker1  - Worker 1 logs")
        print(f"  ch8 logs worker2  - Worker 2 logs")

def cmd_config(action=None):
    """Configure cluster"""
    if action == "edit":
        editor = os.environ.get('EDITOR', 'vim')
        print(f"{Colors.BLUE}Opening master config...{Colors.NC}")
        subprocess.run([editor, "config/master.yaml"])
    elif action == "worker":
        editor = os.environ.get('EDITOR', 'vim')
        print(f"{Colors.BLUE}Opening worker config...{Colors.NC}")
        subprocess.run([editor, "config/worker.yaml"])
    else:
        print(f"{Colors.YELLOW}Configuration commands:{Colors.NC}")
        print(f"  ch8 config edit    - Edit master configuration")
        print(f"  ch8 config worker  - Edit worker configuration")
        print(f"\n{Colors.BLUE}Config files:{Colors.NC}")
        print(f"  config/master.yaml   - Master node settings")
        print(f"  config/worker.yaml   - Worker 1 settings")
        print(f"  config/worker2.yaml  - Worker 2 settings")

def cmd_worker(action=None):
    """Manage workers"""
    if action == "list":
        print(f"{Colors.BLUE}Registered workers:{Colors.NC}\n")
        subprocess.run(["python", "-c", """
import asyncio
import sys
sys.path.insert(0, '/data/ch8-agent')
from cluster.discovery import RedisDiscovery

async def list_workers():
    discovery = RedisDiscovery(
        redis_url='redis://:1q2w3e4r@127.0.0.1:6379/0',
        heartbeat_interval=10
    )
    await discovery.connect()
    workers = await discovery.get_all_workers()

    if not workers:
        print('No workers registered')
    else:
        for w in workers:
            print(f"  • {w['worker_id']}")
            print(f"    Address: {w['address']}")
            print(f"    Capabilities: {', '.join(w['capabilities'])}")
            print(f"    Active tasks: {w.get('active_tasks', 0)}")
            print()

    await discovery.disconnect()

asyncio.run(list_workers())
"""])
    elif action == "add":
        print(f"{Colors.YELLOW}To add a worker:{Colors.NC}")
        print(f"  1. Copy config/worker.yaml to config/worker-new.yaml")
        print(f"  2. Edit worker-new.yaml (change node_id and grpc_port)")
        print(f"  3. Start worker: python cluster/worker.py config/worker-new.yaml")
    else:
        print(f"{Colors.YELLOW}Worker commands:{Colors.NC}")
        print(f"  ch8 worker list   - List all registered workers")
        print(f"  ch8 worker add    - Show how to add a worker")

def cmd_master():
    """Start master only"""
    print(f"{Colors.GREEN}Starting Master Node...{Colors.NC}")
    subprocess.run(["python", "cluster/master.py"])

def cmd_setup():
    """Run setup wizard"""
    print_logo()
    print(f"{Colors.GREEN}CH8 Agent Setup Wizard{Colors.NC}\n")

    # Check Python
    print(f"{Colors.BLUE}1. Checking Python...{Colors.NC}")
    result = subprocess.run(["python3", "--version"], capture_output=True, text=True)
    print(f"   {result.stdout.strip()}")

    # Check Redis
    print(f"\n{Colors.BLUE}2. Checking Redis...{Colors.NC}")
    result = subprocess.run(["redis-cli", "ping"], capture_output=True, text=True)
    if "PONG" in result.stdout:
        print(f"   {Colors.GREEN}✓ Redis is running{Colors.NC}")
    else:
        print(f"   {Colors.RED}✗ Redis not running{Colors.NC}")
        print(f"   Start with: redis-server &")

    # Check venv
    print(f"\n{Colors.BLUE}3. Checking virtual environment...{Colors.NC}")
    if os.path.exists("venv"):
        print(f"   {Colors.GREEN}✓ Virtual environment exists{Colors.NC}")
    else:
        print(f"   {Colors.YELLOW}Creating virtual environment...{Colors.NC}")
        subprocess.run(["python3", "-m", "venv", "venv"])

    # Install dependencies
    print(f"\n{Colors.BLUE}4. Installing dependencies...{Colors.NC}")
    subprocess.run(["venv/bin/pip", "install", "-r", "requirements.txt"])

    print(f"\n{Colors.GREEN}Setup complete!{Colors.NC}")
    print(f"Run: {Colors.YELLOW}ch8 start{Colors.NC} to start the cluster")

def cmd_update():
    """Update to latest version"""
    print(f"{Colors.BLUE}Updating CH8 Agent...{Colors.NC}")
    subprocess.run(["git", "pull", "origin", "master"])
    print(f"{Colors.BLUE}Updating dependencies...{Colors.NC}")
    subprocess.run(["venv/bin/pip", "install", "-r", "requirements.txt", "--upgrade"])
    print(f"{Colors.GREEN}Update complete!{Colors.NC}")

def cmd_doctor():
    """Diagnose issues"""
    print(f"{Colors.BLUE}CH8 Agent System Diagnostics{Colors.NC}\n")

    checks = [
        ("Python version", ["python3", "--version"]),
        ("Redis connection", ["redis-cli", "ping"]),
        ("Virtual environment", ["test", "-d", "venv"]),
        ("Master config", ["test", "-f", "config/master.yaml"]),
        ("Worker config", ["test", "-f", "config/worker.yaml"]),
    ]

    for name, cmd in checks:
        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode == 0:
            print(f"  {Colors.GREEN}✓{Colors.NC} {name}")
        else:
            print(f"  {Colors.RED}✗{Colors.NC} {name}")

    print(f"\n{Colors.BLUE}Cluster processes:{Colors.NC}")
    subprocess.run(["ps", "aux"], stdout=subprocess.PIPE)
    subprocess.run(["grep", "-E", "cluster/(master|worker)"], stdin=subprocess.PIPE)

    print(f"\n{Colors.BLUE}Redis workers:{Colors.NC}")
    subprocess.run(["redis-cli", "-a", "1q2w3e4r", "SMEMBERS", "cluster:workers"])

def main():
    # Change to script directory
    script_dir = Path(__file__).parent.absolute()
    os.chdir(script_dir)

    parser = argparse.ArgumentParser(
        description='CH8 Agent - Distributed Multi-Node Agent System',
        add_help=False
    )
    parser.add_argument('command', nargs='?', default='help')
    parser.add_argument('subcommand', nargs='?', default=None)

    args = parser.parse_args()

    commands = {
        'help': cmd_help,
        'start': cmd_start,
        'stop': cmd_stop,
        'status': cmd_status,
        'test': cmd_test,
        'logs': lambda: cmd_logs(args.subcommand),
        'config': lambda: cmd_config(args.subcommand),
        'worker': lambda: cmd_worker(args.subcommand),
        'master': cmd_master,
        'setup': cmd_setup,
        'update': cmd_update,
        'doctor': cmd_doctor,
    }

    if args.command in commands:
        commands[args.command]()
    else:
        print(f"{Colors.RED}Unknown command: {args.command}{Colors.NC}")
        cmd_help()

if __name__ == '__main__':
    main()
