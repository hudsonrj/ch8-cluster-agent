def cmd_token(action=None):
    """Manage pre-auth tokens."""
    sys.path.insert(0, str(Path(__file__).parent))
    from connect.auth import is_authenticated

    if not is_authenticated():
        print(f"{Colors.RED}Not authenticated. Run `ch8 login` first.{Colors.NC}")
        sys.exit(1)

    if action == "create":
        import asyncio
        from connect.coordinator import ControlClient

        label = input("Token label (optional): ").strip()
        ttl   = input("Validity in hours [168]: ").strip() or "168"

        async def _create():
            c = ControlClient()
            return await c.create_preauth_token(label=label, ttl_hours=int(ttl))

        result = asyncio.run(_create())
        print(f"\n{Colors.GREEN}✓ Token created:{Colors.NC}\n")
        print(f"  {Colors.YELLOW}{result['token']}{Colors.NC}")
        print(f"\n  Expires: {result['expires_at']}")
        print(f"  Use on any machine:")
        print(f"    ch8 up --token {result['token']}\n")
    else:
        print(f"{Colors.YELLOW}Token commands:{Colors.NC}")
        print(f"  ch8 token create   - Create a new pre-auth token")

