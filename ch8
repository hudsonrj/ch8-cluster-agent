def cmd_doctor():
    """Diagnose issues"""
    print(f"{Colors.BLUE}CH8 Agent System Diagnostics{Colors.NC}\n")

    checks = [
        ("Python version", ["python3", "--version"]),
        ("Redis connection", ["redis-cli", "ping"]),
        ("Virtual environment", ["test", "-d", "venv"]),
        ("Master config", ["test", "-f", "config/master.yaml"]),
        ("Worker config", ["test", "-f", "config/worker.yaml"]),
    ]

    for name, cmd in checks:
        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode == 0:
            print(f"  {Colors.GREEN}✓{Colors.NC} {name}")
        else:
            print(f"  {Colors.RED}✗{Colors.NC} {name}")

    print(f"\n{Colors.BLUE}Cluster processes:{Colors.NC}")
    subprocess.run(["ps", "aux"], stdout=subprocess.PIPE)
    subprocess.run(["grep", "-E", "cluster/(master|worker)"], stdin=subprocess.PIPE)

    print(f"\n{Colors.BLUE}Redis workers:{Colors.NC}")
    subprocess.run(["redis-cli", "-a", "1q2w3e4r", "SMEMBERS", "cluster:workers"])

def _load_env():
    """Load environment config from ~/.config/ch8/env if it exists."""
    env_file = Path.home() / ".config" / "ch8" / "env"
    if env_file.exists():
        for line in env_file.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                key, _, val = line.partition("=")
                key, val = key.strip(), val.strip()
                if key and key not in os.environ:
                    os.environ[key] = val


def main():
    _load_env()

    # Change to script directory
    script_dir = Path(__file__).parent.absolute()
    os.chdir(script_dir)

    parser = argparse.ArgumentParser(
        description='CH8 Agent - Autonomous AI Orchestration',
        add_help=False
    )
    parser.add_argument('command', nargs='?', default='help')
    parser.add_argument('subcommand', nargs='?', default=None)
    parser.add_argument('--token', default=None, help='Pre-auth token for headless enrollment')

    args, _ = parser.parse_known_args()

    commands = {
        # Connect (Tailscale-style)
        'login':  cmd_login,
        'up':     lambda: cmd_up(token=args.token),
        'down':   cmd_down,
        'nodes':  cmd_nodes,
        'logout': cmd_logout,
        'token':  lambda: cmd_token(args.subcommand),
        # Cluster
        'start':  cmd_start,
        'stop':   cmd_stop,
        'status': cmd_status,
        'test':   cmd_test,
        'logs':   lambda: cmd_logs(args.subcommand),
        'config': lambda: cmd_config(args.subcommand),
        'worker': lambda: cmd_worker(args.subcommand),
        'master': cmd_master,
        # System
        'setup':  cmd_setup,
        'update': cmd_update,
        'doctor': cmd_doctor,
        'help':   cmd_help,
    }

    if args.command in commands:
        commands[args.command]()
    else:
        print(f"{Colors.RED}Unknown command: {args.command}{Colors.NC}")
        cmd_help()

if __name__ == '__main__':
    main()
