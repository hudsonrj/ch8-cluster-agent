<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0b0f">

    <!-- Setup Layout -->
    <LinearLayout
        android:id="@+id/setup_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CH8"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#6366f1"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Operations Platform"
            android:textSize="14sp"
            android:textColor="#8a93a8"
            android:layout_marginBottom="40dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Control Server URL"
            android:textSize="12sp"
            android:textColor="#8a93a8"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/server_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_bg"
            android:textColor="#f0f2f5"
            android:textColorHint="#505868"
            android:hint="https://control.ch8ai.com.br"
            android:textSize="14sp"
            android:padding="12dp"
            android:singleLine="true"
            android:inputType="textUri"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Token (optional)"
            android:textSize="12sp"
            android:textColor="#8a93a8"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/token_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_bg"
            android:textColor="#f0f2f5"
            android:textColorHint="#505868"
            android:hint="tk_... (for authenticated access)"
            android:textSize="14sp"
            android:padding="12dp"
            android:singleLine="true"
            android:inputType="text"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btn_connect"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Connect"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:backgroundTint="#6366f1"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect via Tailscale for best performance.\nThe app will show the full control dashboard."
            android:textSize="11sp"
            android:textColor="#505868"
            android:gravity="center"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>

    <!-- WebView (full dashboard) -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- Status bar overlay -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#1a1d26"
        android:textColor="#8a93a8"
        android:textSize="11sp"
        android:padding="8dp"
        android:gravity="center"
        android:visibility="gone"/>

    <!-- Hidden buttons for service control -->
    <Button android:id="@+id/btn_start" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>
    <Button android:id="@+id/btn_stop" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>

</RelativeLayout>
